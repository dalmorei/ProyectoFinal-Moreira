# Firebase Configuration
# Copiar este archivo a .env y reemplaza con tus credenciales de Firebase

VITE_FIREBASE_API_KEY=api_key_aqui
VITE_FIREBASE_AUTH_DOMAIN=auth_domain_aqui
VITE_FIREBASE_PROJECT_ID=project_id_aqui
VITE_FIREBASE_STORAGE_BUCKET=storage_bucket_aqui
VITE_FIREBASE_MESSAGING_SENDER_ID=messaging_sender_id_aqui
VITE_FIREBASE_APP_ID=app_id_aqui
